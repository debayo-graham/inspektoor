pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                withEnv(["PATH+FLUTTER=/opt/homebrew/bin:/Users/debayo_egov/tools/flutter/bin:/opt/homebrew/opt/ruby/bin"]) {
                    dir('inspektoor_flutter') {
                        sh 'flutter pub get'
                    }
                }
            }
        }

        stage('Analyze') {
            steps {
                withEnv(["PATH+FLUTTER=/opt/homebrew/bin:/Users/debayo_egov/tools/flutter/bin:/opt/homebrew/opt/ruby/bin"]) {
                    dir('inspektoor_flutter') {
                        sh 'flutter analyze --no-fatal-warnings --no-fatal-infos'
                    }
                }
            }
        }

        stage('Test') {
            steps {
                withEnv(["PATH+FLUTTER=/opt/homebrew/bin:/Users/debayo_egov/tools/flutter/bin:/opt/homebrew/opt/ruby/bin"]) {
                    dir('inspektoor_flutter') {
                        sh 'flutter test'
                    }
                }
            }
        }

        stage('Build Android') {
            steps {
                withEnv(["PATH+FLUTTER=/opt/homebrew/bin:/Users/debayo_egov/tools/flutter/bin:/opt/homebrew/opt/ruby/bin"]) {
                    dir('inspektoor_flutter') {
                        sh 'flutter build appbundle --release'
                    }
                }
            }
        }

        stage('Build iOS') {
            steps {
                withEnv(["PATH+FLUTTER=/opt/homebrew/bin:/Users/debayo_egov/tools/flutter/bin:/opt/homebrew/opt/ruby/bin"]) {
                    dir('inspektoor_flutter') {
                        sh 'flutter build ios --release --no-codesign'
                    }
                }
            }
        }

        stage('Deploy to TestFlight') {
            steps {
                withCredentials([
                    string(credentialsId: 'MATCH_PASSWORD', variable: 'MATCH_PASSWORD'),
                    file(credentialsId: 'APP_STORE_CONNECT_API_KEY', variable: 'APP_STORE_CONNECT_API_KEY_PATH'),
                    string(credentialsId: 'APPLE_ID', variable: 'APPLE_ID'),
                    string(credentialsId: 'APP_STORE_KEY_ID', variable: 'APP_STORE_KEY_ID'),
                    string(credentialsId: 'APP_STORE_ISSUER_ID', variable: 'APP_STORE_ISSUER_ID')
                ]) {
                    withEnv([
                        "PATH+FLUTTER=/opt/homebrew/bin:/Users/debayo_egov/tools/flutter/bin:/opt/homebrew/opt/ruby/bin",
                        "LANG=en_US.UTF-8",
                        "LC_ALL=en_US.UTF-8"
                    ]) {
                        dir('inspektoor_flutter/ios') {
                            sh '/opt/homebrew/opt/ruby/bin/bundle exec fastlane beta'
                        }
                    }
                }
            }
        }

    }

    post {
        success {
            echo '✅ Build and TestFlight deploy succeeded!'
        }
        failure {
            echo '❌ Build failed!'
        }
    }
}